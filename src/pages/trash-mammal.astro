---
import Layout from '../layouts/Layout.astro';
---
<Layout
  title="Malik Danab - Trash Mammal"
  description="Trash Mammal is a game jam stealth puzzle game built in Unreal Engine, about sneaking through the darkness as THE Trash Mammal."
  active="gamejams"
  image="/images/cover-trash-mammal.webp"
>
  <main class="page-modules">
    <h1 class="page-title">Trash Mammal</h1>
    <p class="page-subtitle">Game Jam &middot; Stealth Puzzle &middot; Unreal Engine</p>
    <div class="module-columns">
      <div class="text-block">
        <div>
          Description: A puzzle-based game about staying in the darkness to avoid detection and
          sneaking around as THE Trash Mammal.
        </div>
        <div>Contributions: Character Movement, Animations, and Interactive Elements.</div>
        <div>Engine And Tools: Unreal Engine, Photoshop, Maya, and GitHub.</div>
      </div>
      <div class="image-block">
        <a href="https://zyrthal.itch.io/trash-mammal" target="_blank" rel="noopener">
          <img src="/images/trash-mammal-1.webp" alt="Trash Mammal" width="347" height="347" />
        </a>
      </div>
    </div>
  </main>
</Layout>
