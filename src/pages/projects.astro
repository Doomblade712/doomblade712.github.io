---
import Layout from '../layouts/Layout.astro';

const covers = [
  { href: '/invein', img: '/images/cover-invein.webp', title: 'InVein', date: '2026', hook: 'Sound & gameplay systems · Released on Steam' },
  { href: '/foursight', img: '/images/cover-foursight.png', title: 'FourSight', date: '2026', hook: 'Solo dev · Unity DOTS roguelike tower defense' },
  { href: '/finalprice', img: '/images/cover-finalprice.png', title: 'FinalPrice', date: '2026', hook: 'Chrome extension · Published on the Web Store' },
];
---
<Layout
  title="Malik Danab - Projects"
  description="Released projects by Malik Danab: InVein (psychological horror on Steam), FourSight (solo Unity DOTS tower defense), and FinalPrice (Chrome extension)."
  active="projects"
>
  <main>
    <header class="masthead">
      <h1>Projects</h1>
      <p>"The only thing better than playing games is making one."</p>
    </header>
    <div class="project-covers">
      {covers.map((cover) => (
        <a class="project-cover" href={cover.href}>
          <div class="cover-image">
            <img src={cover.img} alt={cover.title} loading="lazy" />
          </div>
          <div class="cover-details">
            <div class="title">{cover.title}</div>
            <div class="date">{cover.date}</div>
          </div>
          <div class="cover-hook">{cover.hook}</div>
        </a>
      ))}
    </div>
  </main>
</Layout>
