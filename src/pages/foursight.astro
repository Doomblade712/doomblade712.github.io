          <text class="ecs-t" x="424" y="42" text-anchor="end">Burst-compiled</text>
          <text class="ecs-t" x="36" y="60">every component struct lives in Components.cs</text>

          <rect class="ecs-row" x="36" y="72" width="388" height="30" rx="6"></rect>
          <text class="ecs-code" x="48" y="91">EnemyCleanupSystem</text>
          <text class="ecs-t" x="412" y="91" text-anchor="end">dead entities leave all queries</text>
          <line class="ecs-flow" x1="230" y1="102" x2="230" y2="110" marker-end="url(#ecs-arrow)"></line>
          <rect class="ecs-row" x="36" y="112" width="388" height="30" rx="6"></rect>
          <text class="ecs-w" x="48" y="131">Spawn systems</text>
          <text class="ecs-t" x="412" y="131" text-anchor="end">ordered after cleanup</text>
          <line class="ecs-flow" x1="230" y1="142" x2="230" y2="150" marker-end="url(#ecs-arrow)"></line>
          <rect class="ecs-row" x="36" y="152" width="388" height="30" rx="6"></rect>
          <text class="ecs-code" x="48" y="171">EnemyMovementSystem</text>
          <text class="ecs-t" x="412" y="171" text-anchor="end">reads the flow-field blob</text>
          <line class="ecs-flow" x1="230" y1="182" x2="230" y2="190" marker-end="url(#ecs-arrow)"></line>
          <rect class="ecs-row" x="36" y="192" width="388" height="30" rx="6"></rect>
          <text class="ecs-w" x="48" y="211">Attack systems</text>
