          <text class="ecs-t" x="131" y="408" text-anchor="middle" font-size="10.5">TryPlaceCard &rarr; tower entity</text>

          <line stroke="#8ab4ff" stroke-width="1.5" x1="330" y1="352" x2="330" y2="368"></line>
          <line class="ecs-flow" x1="330" y1="424" x2="330" y2="456" marker-end="url(#ecs-arrow)"></line>
          <rect x="236" y="368" width="188" height="56" rx="10" fill="rgba(12,12,16,0.92)" stroke="rgba(255,255,255,0.28)"></rect>
          <text class="ecs-code" x="330" y="390" text-anchor="middle" font-size="11">SimulationAnimationEvents</text>
          <text class="ecs-t" x="330" y="408" text-anchor="middle" font-size="10.5">6 static events &rarr; visual sync</text>

          <text class="ecs-t" x="230" y="446" text-anchor="middle">no GameObjects cross this line</text>

          <rect class="ecs-box" x="20" y="460" width="420" height="146" rx="10"></rect>
          <text class="ecs-h" x="36" y="488">MonoBehaviour Presentation</text>
          <text class="ecs-t" x="424" y="488" text-anchor="end">main thread</text>
          <rect class="ecs-row" x="36" y="502" width="120" height="56" rx="6"></rect>
          <text class="ecs-w" x="96" y="526" text-anchor="middle">Cards &amp; hand</text>
          <text class="ecs-t" x="96" y="543" text-anchor="middle" font-size="10.5">drag, drop, keywords</text>
