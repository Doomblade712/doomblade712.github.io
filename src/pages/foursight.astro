            .kw-t { fill: #c0c6cc; font-size: 11px; }
            .kw-tr { fill: #ff8a80; font-size: 11px; }
            .kw-code { fill: #e8d9a0; font-family: Consolas, 'Courier New', monospace; font-size: 12px; }
            .kw-flow { stroke: #8ab4ff; stroke-width: 1.5; fill: none; }
            .kw-cancel { stroke: #ff8a80; stroke-width: 1.5; fill: none; stroke-dasharray: 5 4; }
          </style>

          <rect class="kw-box" x="20" y="14" width="420" height="176" rx="10"></rect>
          <text class="kw-h" x="36" y="42">CardInfo &middot; "Insight"</text>
          <text class="kw-t" x="424" y="42" text-anchor="end">ScriptableObject</text>
          <text class="kw-t" x="36" y="62">keywords &mdash; KeywordDefinition + per-card override:</text>
          <rect class="kw-row" x="36" y="76" width="388" height="28" rx="6"></rect>
          <text class="kw-t" x="48" y="94.5">[0]</text>
          <text class="kw-code" x="84" y="94.5">Draw</text>
          <text class="kw-t" x="410" y="94.5" text-anchor="end">override: 2</text>
          <rect class="kw-row" x="36" y="110" width="388" height="28" rx="6"></rect>
          <text class="kw-t" x="48" y="128.5">[1]</text>
          <text class="kw-code" x="84" y="128.5">Discard</text>
          <text class="kw-t" x="410" y="128.5" text-anchor="end">override: 1</text>
