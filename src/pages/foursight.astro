          <line class="ecs-flow" x1="230" y1="262" x2="230" y2="270" marker-end="url(#ecs-arrow)"></line>
          <rect class="ecs-row" x="36" y="272" width="388" height="30" rx="6"></rect>
          <text class="ecs-w" x="48" y="291">Health systems</text>
          <text class="ecs-t" x="412" y="291" text-anchor="end">drain buffers same frame &mdash; no races</text>
          <text class="ecs-t" x="36" y="326">26+ systems in an explicitly declared update order</text>

          <line stroke="rgba(255,255,255,0.25)" stroke-width="1" stroke-dasharray="6 5" x1="20" y1="396" x2="440" y2="396"></line>

          <line class="ecs-flow" x1="131" y1="368" x2="131" y2="352" marker-end="url(#ecs-arrow)"></line>
          <line stroke="#8ab4ff" stroke-width="1.5" x1="131" y1="458" x2="131" y2="424"></line>
          <rect x="36" y="368" width="190" height="56" rx="10" fill="rgba(12,12,16,0.92)" stroke="rgba(255,255,255,0.28)"></rect>
