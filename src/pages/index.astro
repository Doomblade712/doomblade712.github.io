---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Malik Danab">
  <main class="splash">
    <div class="splash-inner">
      <h1 class="splash-title">Malik Danab</h1>
      <div class="splash-columns">
        <div class="splash-text">
          A detail-oriented and experienced professional with a strong academic background and
          hands-on experience in software development. With a degree in ATEC(Art's, Technology, and
          Emerging Communication with a Concentration in Animation &amp; Game Design) from the
          University of Texas at Dallas, I have gained knowledge and expertise in various
          programming languages, multimedia design, and user-centered design methodologies.
        </div>
        <div>
          <img class="splash-portrait" src="/images/malik-danab-1.png" alt="Malik Danab" />
        </div>
      </div>
      <div class="splash-buttons">
        <a class="pill-button" href="/about-me">About Me</a>
        <div class="button-row">
          <a class="pill-button" href="/projects">My Projects</a>
          <a class="pill-button" href="/gamejams">My GameJams</a>
        </div>
      </div>
    </div>
  </main>
</Layout>
