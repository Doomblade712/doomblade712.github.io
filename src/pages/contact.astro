---
import Layout from '../layouts/Layout.astro';

// Get a free access key at https://web3forms.com (emailed to you instantly).
// Until this is replaced, the form falls back to opening the visitor's email app.
const WEB3FORMS_ACCESS_KEY = 'YOUR_WEB3FORMS_ACCESS_KEY';
---
<Layout
  title="Malik Danab - Contact"
  description="Get in touch with Malik Danab for gameplay programming and technical design opportunities."
  active="contact"
>
  <main class="page-modules">
    <h1 class="page-title">Contact</h1>
    <div class="text-block">
      <div>
        Fill out the form below, or email me directly at
        <a href="mailto:mtd.danab@gmail.com">mtd.danab@gmail.com</a>.
      </div>
    </div>
    <form class="contact-form" id="contact-form" data-access-key={WEB3FORMS_ACCESS_KEY}>
      <label for="contact-name">Name *</label>
      <input id="contact-name" name="name" type="text" required />

      <label for="contact-email">Email Address *</label>
      <input id="contact-email" name="email" type="email" required />

      <label for="contact-message">Message *</label>
      <textarea id="contact-message" name="message" required></textarea>

      <input type="checkbox" name="botcheck" tabindex="-1" style="display:none" aria-hidden="true" />

      <div class="submit-row">
        <button type="submit" class="pill-button">Submit</button>
      </div>
    </form>
    <p class="text-block" id="contact-sent" hidden>
      Thank you! Your message has been sent.
    </p>
    <p class="text-block" id="contact-fallback" hidden>
      Thank you! Your email app should have opened with the message ready to send. If it didn't,
      email me directly at <a href="mailto:mtd.danab@gmail.com">mtd.danab@gmail.com</a>.
    </p>
  </main>

  <script>
    const form = document.getElementById('contact-form') as HTMLFormElement | null;

    function show(id: string) {
      if (form) form.hidden = true;
      const el = document.getElementById(id);
      if (el) el.hidden = false;
    }

    function mailtoFallback(data: FormData) {
      const subject = `Portfolio contact from ${data.get('name')}`;
      const body = `${data.get('message')}\n\nFrom: ${data.get('name')} <${data.get('email')}>`;
      window.location.href =
        `mailto:mtd.danab@gmail.com?subject=${encodeURIComponent(subject)}&body=${encodeURIComponent(body)}`;
      show('contact-fallback');
    }

    form?.addEventListener('submit', async (event) => {
      event.preventDefault();
      const data = new FormData(form);
      const accessKey = form.dataset.accessKey ?? '';

      if (!accessKey || accessKey === 'YOUR_WEB3FORMS_ACCESS_KEY') {
        mailtoFallback(data);
        return;
      }

      const button = form.querySelector('button');
      if (button) button.disabled = true;
      try {
        const response = await fetch('https://api.web3forms.com/submit', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
          body: JSON.stringify({
            access_key: accessKey,
            subject: `Portfolio contact from ${data.get('name')}`,
            name: data.get('name'),
            email: data.get('email'),
            message: data.get('message'),
            botcheck: data.get('botcheck'),
          }),
        });
        const result = await response.json();
        if (result.success) {
          show('contact-sent');
        } else {
          mailtoFallback(data);
        }
      } catch {
        mailtoFallback(data);
      } finally {
        if (button) button.disabled = false;
      }
    });
  </script>
</Layout>
