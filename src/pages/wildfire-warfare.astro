---
import Layout from '../layouts/Layout.astro';
---
<Layout
  title="Malik Danab - Wildfire Warfare"
  description="Wildfire Warfare is a game jam RTS puzzle game built in Unity, where you command units to stop a spreading forest fire."
  active="gamejams"
  image="/images/cover-wildfire-warfare.webp"
>
  <main class="page-modules">
    <h1 class="page-title">Wildfire Warfare</h1>
    <p class="page-subtitle">Game Jam &middot; RTS Puzzle &middot; Unity</p>
    <div class="module-columns">
      <div class="text-block">
        <div>
          Description: The forest is on fire! Take command of your units to stop the wildfire from
          spreading and "keep it small" in this RTS puzzle game.
        </div>
        <div>
          Contributions: Game Design, Menus, Level Builder, Fire Spreading System, Enemy AI, Player
          Movement, and abilities.
        </div>
        <div>Engine And Tools: Unity, Photoshop, and GitHub.</div>
      </div>
      <div class="image-block">
        <a href="https://web04.itch.io/wildfire-warfare" target="_blank" rel="noopener">
          <img src="/images/wildfire-warfare-1.webp" alt="Wildfire Warfare" width="1400" height="779" />
        </a>
      </div>
    </div>
  </main>
</Layout>
