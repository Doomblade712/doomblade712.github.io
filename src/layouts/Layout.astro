---
import SocialLinks from '../components/SocialLinks.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  /** Which nav link to highlight: 'about-me' | 'projects' | 'gamejams' | 'contact' */
  active?: string;
  /** Image (site-root path) used for link previews on LinkedIn/Discord/etc. */
  image?: string;
  /** Hide the name in the header (the home page already shows it as the splash title). */
  hideLogo?: boolean;
}

const {
  title,
  description = 'Gameplay Programmer and Technical Designer specializing in C#, C++, and UE5. Explore my portfolio featuring solo projects like FourSight and technical sound design for InVein.',
  active = '',
  image = '/images/malik-danab-1.webp',
  hideLogo = false,
} = Astro.props;

// Pages deploy as folders, so the served URL always ends in a slash.
const canonicalPath = Astro.url.pathname.endsWith('/') ? Astro.url.pathname : `${Astro.url.pathname}/`;
const canonical = new URL(canonicalPath, Astro.site);
const socialImage = new URL(image, Astro.site);

const navLinks = [
  { key: 'about-me', href: '/about-me', label: 'About Me' },
  { key: 'projects', href: '/projects', label: 'Projects' },
  { key: 'gamejams', href: '/gamejams', label: 'GameJams' },
  { key: 'resume', href: '/resume.pdf', label: 'Résumé', newTab: true },
  { key: 'contact', href: '/contact', label: 'Contact' },
];
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Malik Danab" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={socialImage} />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={socialImage} />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link rel="icon" href="/images/favicon.jpg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Jost:wght@400;600;700&family=Quicksand:wght@700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <header class="site-header">
      <button class="hamburger" aria-label="Open menu" aria-expanded="false" aria-controls="mobile-nav">
        <i></i><i></i><i></i>
      </button>
      <nav class="nav-links" aria-label="Main">
        {navLinks.map((link) => (
          <a
            href={link.href}
            class={active === link.key ? 'active' : undefined}
            target={link.newTab ? '_blank' : undefined}
            rel={link.newTab ? 'noopener' : undefined}
          >{link.label}</a>
        ))}
      </nav>
      {!hideLogo && <a href="/" class="site-logo">Malik Danab</a>}
      <SocialLinks />
    </header>

    <nav class="responsive-nav" id="mobile-nav" aria-label="Mobile">
      <button class="close-nav" aria-label="Close menu">&times;</button>
      {navLinks.map((link) => (
        <a href={link.href} target={link.newTab ? '_blank' : undefined} rel={link.newTab ? 'noopener' : undefined}>
          {link.label}
        </a>
      ))}
    </nav>

    <slot />

    <footer class="site-footer">
      <SocialLinks />
      <div class="copyright">&copy; {new Date().getFullYear()} by Malik Danab</div>
    </footer>

    <a href="#top" class="back-to-top" aria-label="Back to top">
      <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <path d="M4 15l8-8 8 8-1.5 1.5L12 10l-6.5 6.5z" />
      </svg>
    </a>

    <script>
      const panel = document.querySelector('.responsive-nav');
      const hamburger = document.querySelector<HTMLButtonElement>('.hamburger');
      const closeNav = document.querySelector<HTMLButtonElement>('.close-nav');
      const openMenu = () => {
        panel?.classList.add('open');
        hamburger?.setAttribute('aria-expanded', 'true');
        closeNav?.focus();
      };
      const closeMenu = (refocus = true) => {
        panel?.classList.remove('open');
        hamburger?.setAttribute('aria-expanded', 'false');
        if (refocus) hamburger?.focus();
      };
      hamburger?.addEventListener('click', openMenu);
      closeNav?.addEventListener('click', () => closeMenu());
      panel?.querySelectorAll('a').forEach((a) => a.addEventListener('click', () => closeMenu(false)));
      document.addEventListener('keydown', (event) => {
        if (event.key === 'Escape' && panel?.classList.contains('open')) closeMenu();
      });

      const backToTop = document.querySelector('.back-to-top');
      const toggleBackToTop = () => backToTop?.classList.toggle('visible', window.scrollY > 300);
      window.addEventListener('scroll', toggleBackToTop, { passive: true });
      toggleBackToTop();
      backToTop?.addEventListener('click', (event) => {
        event.preventDefault();
        window.scrollTo({ top: 0, behavior: 'smooth' });
      });

      // Subtle synthesized UI sounds — no audio files needed.
      // Browsers block audio until the first real interaction, so the context
      // is created on pointerdown/keydown and hover ticks stay silent until then.
      let audioCtx: AudioContext | null = null;
      const unlockAudio = () => {
        if (!audioCtx) {
          audioCtx = new AudioContext();
          // Once audio actually runs, remember it for the rest of the visit so
          // later page loads can start sound without waiting for a click.
          audioCtx.onstatechange = () => {
            if (audioCtx?.state === 'running') sessionStorage.setItem('sound-unlocked', '1');
          };
        }
        if (audioCtx.state === 'suspended') audioCtx.resume();
        else if (audioCtx.state === 'running') sessionStorage.setItem('sound-unlocked', '1');
      };
      document.addEventListener('pointerdown', unlockAudio, { capture: true });
      document.addEventListener('keydown', unlockAudio, { capture: true });
      // Chromium carries user activation across same-site navigations, so after
      // the visitor's first interaction anywhere on the site this succeeds on
      // load; browsers that refuse just fall back to the listeners above.
      if (sessionStorage.getItem('sound-unlocked')) unlockAudio();

      const blip = (freq: number, duration: number, peak: number, type: OscillatorType = 'sine') => {
        // Skip while suspended: scheduling then would stack sounds at time 0
        // and release them all at once on the first click.
        if (!audioCtx || audioCtx.state !== 'running') return;
        const osc = audioCtx.createOscillator();
        const gain = audioCtx.createGain();
        osc.type = type;
        osc.frequency.setValueAtTime(freq, audioCtx.currentTime);
        osc.frequency.exponentialRampToValueAtTime(freq * 0.6, audioCtx.currentTime + duration);
        gain.gain.setValueAtTime(peak, audioCtx.currentTime);
        gain.gain.exponentialRampToValueAtTime(0.0001, audioCtx.currentTime + duration);
        osc.connect(gain).connect(audioCtx.destination);
        osc.start();
        osc.stop(audioCtx.currentTime + duration);
      };

      const interactive = 'a, button';
      if (window.matchMedia('(hover: hover)').matches) {
        document.addEventListener('mouseover', (event) => {
          const target = (event.target as Element).closest(interactive);
          const from = event.relatedTarget as Node | null;
          if (target && (!from || !target.contains(from))) blip(1800, 0.05, 0.04);
        });
      }
      document.addEventListener('click', (event) => {
        if ((event.target as Element).closest(interactive)) blip(900, 0.09, 0.1, 'triangle');
      });
    </script>
  </body>
</html>
